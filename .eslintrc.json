{
  "env": {
    "browser": false,
    "es6": true,
    "node": true
  },
  "extends": [
    "airbnb-base",
    "airbnb-typescript/base"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "settings": {
    "import/resolver": {
      "eslint-import-resolver-custom-alias": {
        "alias": {
          "@": "./src"
        },
        "extensions": [
          ".ts"
        ]
      }
    }
  },
  "rules": {
    "import/no-restricted-paths": ["error", {
      "zones": [
        {
          "target": "./src/service",
          "from": "./src/core/nnkBot.ts",
          "message": "service 层不要依赖 nnkBot 单例，配置请从 @/core/nnkConfig 获取"
        },
        {
          "target": "./src/service",
          "from": "./src/modules",
          "message": "service 层不要依赖 modules"
        },
        {
          "target": "./src/service",
          "from": "./src/tasks",
          "message": "service 层不要依赖 tasks"
        },
        {
          "target": "./src/modules",
          "from": "./src/tasks",
          "message": "modules 不要依赖 tasks，公共逻辑请下沉到 service 层"
        },
        {
          "target": "./src/core",
          "from": "./src/tasks",
          "message": "core 不要依赖 tasks"
        },
        {
          "target": "./src/core",
          "from": "./src/service",
          "message": "core 不要依赖 service"
        },
        {
          "target": "./src/utils",
          "from": "./src/core",
          "message": "utils 应保持零业务依赖"
        },
        {
          "target": "./src/utils",
          "from": "./src/modules",
          "message": "utils 应保持零业务依赖"
        },
        {
          "target": "./src/utils",
          "from": "./src/service",
          "message": "utils 应保持零业务依赖"
        },
        {
          "target": "./src/utils",
          "from": "./src/tasks",
          "message": "utils 应保持零业务依赖"
        }
      ]
    }],
    "@typescript-eslint/no-unused-vars": "off",
    "@typescript-eslint/no-use-before-define": "off",
    "@typescript-eslint/naming-convention": "off",
    "import/prefer-default-export": "off",
    "no-use-before-define": "off",
    "camelcase": "off",
    "max-len": "off",
    "class-methods-use-this": "off",
    "radix": "off",
    "prefer-spread": "off",
    "consistent-return": "off",
    "no-restricted-syntax": "off",
    "no-await-in-loop": "off",
    "no-nested-ternary": "off",
    "linebreak-style": "off",
    "no-multiple-empty-lines": "off",
    "no-console": "off",
    "no-plusplus": "off"
  }
}